# --- Database ---
DATABASE_URL=postgresql://agentgate:agentgate@localhost:5433/agentgate?schema=public

# --- AgentGate API ---
AGENTGATE_JWT_SECRET=replace-with-32+-char-random-string

# --- Base Sepolia (on-chain anchor) ---
BASE_RPC_URL=https://your-base-sepolia-rpc-url
DEPLOYER_PRIVATE_KEY=0x_your_funded_base_sepolia_test_wallet_private_key
AUDIT_LOGGER_ADDRESS=

# --- Frontend (NEXT_PUBLIC_ vars are exposed to the browser) ---
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_BASE_EXPLORER=https://sepolia.basescan.org
